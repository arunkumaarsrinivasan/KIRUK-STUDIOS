{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/arunk/KIRUKULAM/KIRUK-STUDIOS/scripts/capture-session.mjs",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run tokens:build)",
      "Bash(npm run tokens:sync-pen)",
      "Bash(npm run spec:validate)",
      "Bash(npm run spec:list)",
      "Bash(npx openspec validate:*)",
      "Bash(npx openspec list:*)",
      "Bash(node scripts/*.mjs:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git init)"
    ],
    "deny": [
      "Read(design-system/pen-files/*.pen)",
      "Grep(design-system/pen-files/*.pen)"
    ]
  }
}
