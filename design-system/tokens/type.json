{
  "font-rational": { "$type": "fontFamily", "$value": "{fontFamily.rational}" },
  "font-expressive": { "$type": "fontFamily", "$value": "{fontFamily.expressive}" },
  "font-mono": { "$type": "fontFamily", "$value": "{fontFamily.mono}" },
  "scale": {
    "xs": { "$type": "dimension", "$value": "12px" },
    "sm": { "$type": "dimension", "$value": "14px" },
    "base": { "$type": "dimension", "$value": "16px" },
    "md": { "$type": "dimension", "$value": "18px" },
    "lg": { "$type": "dimension", "$value": "24px" },
    "xl": { "$type": "dimension", "$value": "32px" },
    "2xl": { "$type": "dimension", "$value": "48px" },
    "3xl": { "$type": "dimension", "$value": "72px" },
    "display": { "$type": "dimension", "$value": "112px" }
  },
  "leading": {
    "tight": { "$type": "number", "$value": 1.05 },
    "snug": { "$type": "number", "$value": 1.2 },
    "normal": { "$type": "number", "$value": 1.5 },
    "loose": { "$type": "number", "$value": 1.75 }
  },
  "tracking": {
    "tight": { "$type": "dimension", "$value": "-0.02em" },
    "normal": { "$type": "dimension", "$value": "0em" },
    "wide": { "$type": "dimension", "$value": "0.08em" }
  }
}
