{
  "$description": "Kiruk Studio — core primitive tokens. Layer 1. No aliases. Do not reference from UI code directly; use semantic.json.",
  "color": {
    "void": { "$type": "color", "$value": "#0A0A0B", "$description": "Deep background — the unwritten universe." },
    "scribble-ink": { "$type": "color", "$value": "#F5F3EE", "$description": "Primary foreground — the scribble line on paper." },
    "paper": { "$type": "color", "$value": "#EFEADF", "$description": "Warm off-white — the page before kirukal." },
    "iris-core": { "$type": "color", "$value": "#FF4D2E", "$description": "Accent 1 — the iris. Alive, direct." },
    "portal-glow": { "$type": "color", "$value": "#7C4DFF", "$description": "Accent 2 — portal transitions." },
    "gaze-dim": { "$type": "color", "$value": "#3A3A3F", "$description": "Muted foreground — looked-at but not focused." },
    "halo-warm": { "$type": "color", "$value": "#FFD166", "$description": "Warm highlight — eye halo." },
    "kohl": { "$type": "color", "$value": "#1A1A1C", "$description": "Near-black — strong borders, outline strokes." }
  },
  "dimension": {
    "space": {
      "0": { "$type": "dimension", "$value": "0px" },
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "24px" },
      "6": { "$type": "dimension", "$value": "32px" },
      "7": { "$type": "dimension", "$value": "48px" },
      "8": { "$type": "dimension", "$value": "64px" },
      "9": { "$type": "dimension", "$value": "96px" }
    }
  },
  "fontFamily": {
    "rational": { "$type": "fontFamily", "$value": "\"Inter\", ui-sans-serif, system-ui, sans-serif", "$description": "Structural face — UI, grids, forms. Swap to locked pick during Phase 1." },
    "expressive": { "$type": "fontFamily", "$value": "\"Instrument Serif\", Georgia, serif", "$description": "Heading face — manifesto voice, poster moments. Swap to locked pick during Phase 1." },
    "mono": { "$type": "fontFamily", "$value": "\"JetBrains Mono\", ui-monospace, monospace" }
  },
  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium": { "$type": "fontWeight", "$value": 500 },
    "bold": { "$type": "fontWeight", "$value": 700 }
  },
  "duration": {
    "instant": { "$type": "duration", "$value": "80ms" },
    "fast": { "$type": "duration", "$value": "180ms" },
    "base": { "$type": "duration", "$value": "280ms" },
    "slow": { "$type": "duration", "$value": "520ms" },
    "portal": { "$type": "duration", "$value": "900ms", "$description": "Between-universe transition." }
  },
  "cubicBezier": {
    "ease-gaze": { "$type": "cubicBezier", "$value": [0.2, 0.8, 0.2, 1], "$description": "Gaze-tracking smoothness." },
    "ease-iris": { "$type": "cubicBezier", "$value": [0.65, 0, 0.35, 1], "$description": "Iris dilation — quick-out, settle." },
    "ease-portal": { "$type": "cubicBezier", "$value": [0.87, 0, 0.13, 1], "$description": "Portal collapse/expand." }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "iris": { "$type": "dimension", "$value": "9999px", "$description": "Full round — iris shape." }
  }
}
